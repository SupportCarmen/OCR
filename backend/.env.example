# ===========================================
# AI OCR Bank Receipt Backend Configuration
# ===========================================

# OpenRouter API (ใช้ LLM Vision ทำ OCR โดยตรง)
# สมัครได้ที่ https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=google/gemini-2.5-flash-preview
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Application Settings
APP_HOST=0.0.0.0
APP_PORT=8010
APP_DEBUG=true

# Upload Settings
MAX_FILE_SIZE_MB=20
UPLOAD_DIR=./uploads
EXPORT_DIR=./exports

# Database
DATABASE_URL=sqlite+aiosqlite:///./ocr_database.db
