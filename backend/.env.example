# ===========================================
# AI OCR Bank Receipt Backend Configuration
# ===========================================

# OpenRouter API (ใช้ LLM Vision ทำ OCR โดยตรง)
# สมัครได้ที่ https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_OCR_MODEL=google/gemini-2.0-flash-001
OPENROUTER_AP_INVOICE_MODEL=google/gemini-2.0-flash-001
OPENROUTER_SUGGESTION_MODEL=google/gemini-2.0-flash-001
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Application Settings
APP_HOST=0.0.0.0
APP_PORT=8010
APP_DEBUG=true

# Upload Settings
MAX_FILE_SIZE_MB=20
UPLOAD_DIR=./uploads
EXPORT_DIR=./exports

# Database (MariaDB)
DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/ocr_db

# Carmen ERP
CARMEN_AUTHORIZATION=direct <token>

# Authentication — REQUIRED in production
# Generate SESSION_ENCRYPTION_KEY: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
OCR_JWT_SECRET=change-this-to-a-long-random-string-in-production
SESSION_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
SESSION_TTL_HOURS=8

# Application version (bump on every release)
APP_VERSION=1.0.0
